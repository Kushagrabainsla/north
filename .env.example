# .env.example
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# All variables are read by config/settings.py via pydantic-settings.
# The Settings class declares env_prefix = "NORTH_" (see docs/CODING_STYLE.md
# Section 17.1), so every field name is prefixed with NORTH_ when read
# from the environment. A field named `openrouter_api_key` is therefore
# loaded from NORTH_OPENROUTER_API_KEY; a field named `north_home` is
# loaded from NORTH_NORTH_HOME (double prefix is intentional).

# Required: your OpenRouter API key. Used for LLM inference AND audio
# transcription (see README Sections 8 and 16.6).
# Get one at https://openrouter.ai/keys
NORTH_OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: root directory where north stores all data
# Default: ~/.north
# NORTH_NORTH_HOME=~/.north

# Optional: runtime environment.
# Default: development. Other values: production, test.
# NORTH_NORTH_ENV=development

# Optional: how often the job processor polls jobs.db, in seconds.
# Default: 5
# NORTH_JOB_POLL_INTERVAL_SECONDS=5
