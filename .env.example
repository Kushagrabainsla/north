# .env.example — copy to .env and fill in real values. Never commit .env.
#
# All variables are read by config/settings.py (pydantic-settings).
# Prefix: NORTH_  e.g. field `openrouter_api_key` → NORTH_OPENROUTER_API_KEY

# ── Required ──────────────────────────────────────────────────────────────────

# Your OpenRouter API key. Used for LLM inference AND voice transcription.
# Get one at https://openrouter.ai/keys
NORTH_OPENROUTER_API_KEY=sk-or-your-key-here

# ── Paths ─────────────────────────────────────────────────────────────────────

# Root directory where north stores all runtime data:
# ledger.db, jobs.db, inference_cache.json, secret.key, context/, tasks/
# Default: ~/.north
# NORTH_NORTH_HOME=~/.north

# ── Runtime environment ───────────────────────────────────────────────────────

# development | production | test
# Default: development
# NORTH_NORTH_ENV=development

# ── Tuning ────────────────────────────────────────────────────────────────────

# How often the job processor polls jobs.db, in seconds. Default: 5
# NORTH_JOB_POLL_INTERVAL_SECONDS=5

# Timeout waiting for an agent to respond, in seconds. Default: 30
# NORTH_AGENT_READ_TIMEOUT_SECONDS=30

# Days before completed task files are cleaned up. Default: 7
# NORTH_TASK_CLEANUP_COMPLETED_DAYS=7

# Days before failed task files are cleaned up. Default: 30
# NORTH_TASK_CLEANUP_FAILED_DAYS=30

# How often the inference router refreshes model pool membership, in hours. Default: 6
# NORTH_INFERENCE_POOL_REFRESH_INTERVAL_HOURS=6

# ── Confidence scoring ────────────────────────────────────────────────────────

# How much confidence increases when a tool use is confirmed helpful. Default: 0.05
# NORTH_CONFIDENCE_INCREASE_PER_HELPFUL_USE=0.05

# How much confidence decreases when a tool use is unhelpful. Default: 0.03
# NORTH_CONFIDENCE_DECREASE_PER_UNHELPFUL_USE=0.03

# Confidence threshold above which tool use is auto-approved. Default: 0.8
# NORTH_CONFIDENCE_AUTO_APPROVE_THRESHOLD=0.8
